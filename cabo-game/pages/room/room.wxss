.room-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a2a6c 0%, #203a43 50%, #2c5364 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.room-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.room-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 24rpx;
}

.room-id-box {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.room-id-label {
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
  margin-right: 16rpx;
}

.room-id-value {
  color: #29ffc6;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.copy-btn {
  color: #29ffc6;
  font-size: 24rpx;
  margin-left: 16rpx;
  padding: 8rpx 16rpx;
  background: rgba(41, 255, 198, 0.2);
  border-radius: 12rpx;
}

.section-title {
  display: block;
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.players-section {
  margin-bottom: 40rpx;
}

.players-list {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.player-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.player-item:last-child {
  border-bottom: none;
}

.player-item.ready {
  background: rgba(41, 255, 198, 0.1);
}

.player-item.empty {
  opacity: 0.5;
}

.player-avatar {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: bold;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.empty-avatar {
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.5);
}

.player-info {
  flex: 1;
}

.player-name {
  display: block;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.empty-text {
  color: rgba(255, 255, 255, 0.5);
}

.player-status {
  display: block;
  color: rgba(255, 255, 255, 0.5);
  font-size: 22rpx;
  margin-top: 4rpx;
}

.ready-badge {
  width: 40rpx;
  height: 40rpx;
  background: #29ffc6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1a1a2e;
  font-weight: bold;
}

.settings-section {
  margin-bottom: 40rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.setting-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 26rpx;
}

.setting-value {
  color: #fff;
  font-size: 26rpx;
}

.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: auto;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  font-weight: bold;
  border: none;
  padding: 28rpx;
  font-size: 32rpx;
}

.btn-primary {
  background: linear-gradient(90deg, #0cebeb, #20e3b2, #29ffc6);
  color: #1a1a2e;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.5);
}

.btn-danger {
  background: rgba(255, 107, 107, 0.2);
  color: #ff6b6b;
}

.btn-large {
  padding: 32rpx;
}
