.home-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a2a6c 0%, #203a43 50%, #2c5364 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  margin-top: 80rpx;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.logo-emoji {
  font-size: 80rpx;
}

.title {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 16rpx;
  font-style: italic;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 4rpx;
}

.action-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  font-weight: bold;
  border: none;
  padding: 28rpx;
  font-size: 32rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(90deg, #0cebeb, #20e3b2, #29ffc6);
  color: #1a1a2e;
  box-shadow: 0 8rpx 24rpx rgba(12, 235, 235, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #fff;
}

.btn-large {
  padding: 36rpx;
  font-size: 36rpx;
}

.btn-icon {
  margin-right: 12rpx;
}

.player-count-section {
  margin-bottom: 40rpx;
}

.section-label {
  display: block;
  color: rgba(255, 255, 255, 0.5);
  font-size: 22rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.player-count-options {
  display: flex;
  gap: 16rpx;
}

.count-option {
  flex: 1;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.count-option.selected {
  background: rgba(41, 255, 198, 0.2);
  border-color: #29ffc6;
  color: #29ffc6;
}

.history-section {
  margin-top: auto;
}

.history-list {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.history-item:last-child {
  border-bottom: none;
}

.history-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.history-result {
  font-size: 28rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.7);
}

.history-result.winner {
  color: #4ecdc4;
}

.history-score {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.history-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.rules-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(5rpx);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #fff;
  border-radius: 32rpx;
  width: 90%;
  max-width: 600rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.rules-scroll {
  flex: 1;
  padding: 24rpx 32rpx;
  max-height: 60vh;
}

.rule-section {
  margin-bottom: 32rpx;
}

.rule-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1a2a6c;
  margin-bottom: 12rpx;
}

.rule-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.ability-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ability-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.ability-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-weight: bold;
  font-size: 24rpx;
}

.ability-desc {
  font-size: 26rpx;
  color: #333;
}

.animate-float {
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}
