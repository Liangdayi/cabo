.game-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a2a6c 0%, #203a43 50%, #2c5364 100%);
  padding: 20rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.8);
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
}

.back-btn:active {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(0.95);
}

.back-icon {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.round-badge {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.score-badge {
  background: linear-gradient(90deg, #0cebeb, #20e3b2);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  color: #1a1a2e;
  font-size: 24rpx;
  font-weight: bold;
}

.opponents-area {
  margin-bottom: 30rpx;
}

.opponent {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.opponent-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.opponent-avatar {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: bold;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.opponent-detail {
  display: flex;
  flex-direction: column;
}

.opponent-name {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.opponent-score {
  color: rgba(255, 255, 255, 0.6);
  font-size: 22rpx;
}

.opponent-cards {
  display: flex;
  gap: 12rpx;
}

.center-area {
  margin-bottom: 30rpx;
}

.pile-area {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  margin-bottom: 20rpx;
}

.pile {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pile-card {
  width: 120rpx;
  height: 160rpx;
  margin-bottom: 12rpx;
}

.pile-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
}

.pile-count {
  color: #29ffc6;
  font-size: 20rpx;
  margin-top: 4rpx;
}

.pile-icon {
  font-size: 48rpx;
}

.turn-indicator {
  text-align: center;
  padding: 16rpx;
  background: rgba(41, 255, 198, 0.2);
  border-radius: 12rpx;
  border: 1rpx solid rgba(41, 255, 198, 0.3);
}

.turn-indicator.opponent-turn {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
}

.turn-text {
  color: #29ffc6;
  font-size: 26rpx;
  font-weight: bold;
}

.turn-indicator.opponent-turn .turn-text {
  color: rgba(255, 255, 255, 0.8);
}

.player-area {
  background: rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  margin: 0 -20rpx;
}

.player-score-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-scores {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-label {
  color: rgba(255, 255, 255, 0.6);
  font-size: 22rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.history-item {
  color: rgba(255, 255, 255, 0.8);
  font-size: 22rpx;
}

.history-empty {
  color: rgba(255, 255, 255, 0.5);
  font-size: 22rpx;
}

.cabo-btn {
  background: linear-gradient(90deg, #ffd93d, #f5c800);
  color: #1a1a2e;
  font-size: 26rpx;
  font-weight: bold;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  border: none;
}

.cabo-btn.disabled {
  background: rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.5);
}

.my-cards {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.card {
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.3s ease;
}

.card:active {
  transform: scale(1.05);
}

.card-back {
  background: linear-gradient(135deg, #1e3a8a, #3b82f6);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.8);
}

.card-front {
  background: #fff;
  border: 2rpx solid #ddd;
  color: #1a1a2e;
}

.card-empty {
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx dashed rgba(255, 255, 255, 0.3);
}

.card-small {
  width: 60rpx;
  height: 80rpx;
}

.card-small .card-value {
  font-size: 24rpx;
}

.card:not(.card-small):not(.pile-card):not(.exchange-card):not(.swap-card) {
  width: 140rpx;
  height: 180rpx;
}

.card-value {
  font-size: 48rpx;
  font-weight: bold;
  line-height: 1;
}

.card-suit {
  font-size: 32rpx;
  margin-top: 8rpx;
}

.card-index {
  font-size: 36rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.6);
}

.ability-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: linear-gradient(135deg, #4ecdc4, #2ecc71);
  color: #fff;
  font-size: 16rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}

.action-sheet {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.action-sheet-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.action-sheet-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #1c1c1e;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  animation: slideUp 0.3s ease;
}

.drawn-card-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.drawn-card {
  width: 160rpx;
  height: 200rpx;
  margin-bottom: 16rpx;
}

.drawn-card-label {
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
}

.ability-hint {
  color: #4ecdc4;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.action-btn-primary {
  background: linear-gradient(90deg, #667eea, #764ba2);
  color: #fff;
}

.action-btn-warning {
  background: linear-gradient(90deg, #f093fb, #f5576c);
  color: #fff;
}

.action-btn-danger {
  background: rgba(255, 255, 255, 0.1);
  color: #ff6b6b;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #1c1c1e;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 90%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-title {
  display: block;
  text-align: center;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.modal-hint {
  display: block;
  text-align: center;
  color: rgba(255, 255, 255, 0.6);
  font-size: 26rpx;
  margin-bottom: 30rpx;
}

.exchange-cards {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  flex-wrap: wrap;
  margin-bottom: 30rpx;
  padding: 20rpx;
}

.exchange-card {
  width: 120rpx;
  height: 160rpx;
  transition: all 0.3s ease;
  position: relative;
}

.exchange-card.selected {
  box-shadow: 0 0 0 6rpx #29ffc6, 0 8rpx 24rpx rgba(41, 255, 198, 0.4) !important;
  transform: scale(1.08);
  border-color: #29ffc6 !important;
  z-index: 100;
}

.select-mark {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #29ffc6, #20e3b2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1a1a2e;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(41, 255, 198, 0.5);
  z-index: 10;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.modal-btn-cancel {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.8);
}

.modal-btn-confirm {
  background: linear-gradient(90deg, #0cebeb, #20e3b2);
  color: #1a1a2e;
}

.spy-targets {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-bottom: 30rpx;
}

.spy-target {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.spy-target:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(1.05);
}

.spy-target text {
  color: #fff;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.spy-cards {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 30rpx;
}

.spy-card {
  width: 120rpx;
  height: 160rpx;
}

.swap-modal {
  max-height: 85vh;
}

.swap-section {
  margin-bottom: 24rpx;
}

.swap-label {
  display: block;
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.swap-cards {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.swap-card {
  width: 100rpx;
  height: 130rpx;
}

.swap-card.selected {
  box-shadow: 0 0 0 4rpx #29ffc6;
}

.result-modal {
  max-height: 80vh;
}

.ability-result-modal {
  max-width: 500rpx;
}

.ability-result-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 30rpx 0;
}

.ability-hint {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.ability-result-card {
  width: 160rpx;
  height: 220rpx;
}

.winner-text {
  display: block;
  text-align: center;
  color: #ffd93d;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.result-list {
  margin-bottom: 24rpx;
}

.result-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
  gap: 8rpx;
}

.result-item.winner {
  background: rgba(255, 217, 61, 0.2);
  border: 1rpx solid rgba(255, 217, 61, 0.3);
}

.result-name {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  min-width: 100rpx;
}

.result-hand,
.result-round,
.result-total {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

.result-cabo {
  background: linear-gradient(90deg, #ffd93d, #f5c800);
  color: #1a1a2e;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { 
    opacity: 0;
    transform: translateY(100rpx);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}

.peek-phase-modal .peek-content {
  max-width: 650rpx;
}

.peek-cards-select {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 30rpx;
}

.peek-card {
  width: 130rpx;
  height: 170rpx;
  transition: all 0.3s ease;
}

.peek-card.selected {
  box-shadow: 0 0 0 4rpx #29ffc6;
  transform: scale(1.05);
}

.peek-viewing {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.countdown-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.countdown-number {
  font-size: 80rpx;
  font-weight: bold;
  color: #29ffc6;
  line-height: 1;
  animation: pulse 1s ease-in-out infinite;
}

.countdown-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.8;
  }
}

.peek-cards-view {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.peek-view-card {
  width: 150rpx;
  height: 200rpx;
  position: relative;
}

.peek-view-card .card-position {
  position: absolute;
  bottom: -30rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  white-space: nowrap;
}

.modal-btn.disabled {
  opacity: 0.5;
  background: rgba(255, 255, 255, 0.3);
}

/* 卡片交互动画 */

/* 抽牌动画 - 从抽牌堆飞出，飞入具体手牌位置 */
@keyframes drawCard {
  0% {
    transform: scale(0.8) rotate(-15deg) translate(-20rpx, -20rpx);
    opacity: 0;
  }
  50% {
    transform: scale(1.2) rotate(15deg) translate(10rpx, -10rpx);
    opacity: 0.8;
  }
  100% {
    transform: scale(1) rotate(0deg) translate(0, 0);
    opacity: 1;
  }
}

.card-draw {
  animation: drawCard 0.6s ease-out;
}

/* 弃牌动画 - 飞入弃牌堆，逐渐缩小并淡出 */
@keyframes discardCard {
  0% {
    transform: scale(1) rotate(0deg) translate(0, 0);
    opacity: 1;
  }
  100% {
    transform: scale(0.6) rotate(-15deg) translate(20rpx, 20rpx);
    opacity: 0;
  }
}

.card-discard {
  animation: discardCard 0.5s ease-in;
}

/* 交换动画 - 从抽牌堆/弃牌堆飞出，飞入目标位置 */
@keyframes exchangeCard {
  0% {
    transform: scale(0.8) rotate(-10deg) translate(-30rpx, -30rpx);
    opacity: 0;
  }
  50% {
    transform: scale(1.1) rotate(10deg) translate(15rpx, -15rpx);
    opacity: 0.8;
  }
  100% {
    transform: scale(1) rotate(0deg) translate(0, 0);
    opacity: 1;
  }
}

.card-exchange {
  animation: exchangeCard 0.6s ease-in-out;
}

/* 技能动画 - 旋转和缩放效果，突出技能发动 */
@keyframes abilityCard {
  0% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
  25% {
    transform: scale(1.2) rotate(10deg);
    opacity: 0.9;
  }
  50% {
    transform: scale(1.3) rotate(-10deg);
    opacity: 0.8;
  }
  75% {
    transform: scale(1.2) rotate(10deg);
    opacity: 0.9;
  }
  100% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

.card-ability {
  animation: abilityCard 0.8s ease-in-out;
}

/* 卡片飞入动画 */
@keyframes flyIn {
  0% {
    transform: scale(0) rotate(-45deg) translate(-50rpx, -50rpx);
    opacity: 0;
  }
  100% {
    transform: scale(1) rotate(0deg) translate(0, 0);
    opacity: 1;
  }
}

.card-fly-in {
  animation: flyIn 0.5s ease-out;
}

/* 卡片飞出动画 */
@keyframes flyOut {
  0% {
    transform: scale(1) rotate(0deg) translate(0, 0);
    opacity: 1;
  }
  100% {
    transform: scale(0) rotate(45deg) translate(50rpx, 50rpx);
    opacity: 0;
  }
}

.card-fly-out {
  animation: flyOut 0.5s ease-in;
}

/* 手牌位置交换动画 */
@keyframes handCardExchange {
  0% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
  50% {
    transform: scale(1.1) rotate(5deg) translate(20rpx, -10rpx);
    opacity: 0.8;
  }
  100% {
    transform: scale(1) rotate(0deg) translate(0, 0);
    opacity: 1;
  }
}

.card-hand-exchange {
  animation: handCardExchange 0.6s ease-in-out;
}

/* ============ 卡牌区域间飞行动画 ============ */

/* 飞行动画容器 */
.flying-card-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: 99999;
}

/* 飞行中的卡牌 - 使用transition实现平滑移动 */
.flying-card {
  position: fixed;
  width: 140rpx;
  height: 180rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.8), 0 0 0 4rpx rgba(255, 255, 255, 0.3);
  will-change: transform, opacity, left, top;
  z-index: 100000;
  transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.flying-card.flying {
  /* 飞行中的状态 */
}

.flying-card.card-back {
  background: linear-gradient(135deg, #1e3a8a, #3b82f6);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
}

.flying-card.card-front {
  background: #fff;
  border: 2rpx solid #ddd;
}

.flying-card .card-value {
  font-size: 40rpx;
  font-weight: bold;
  line-height: 1;
}

.flying-card .card-suit {
  font-size: 28rpx;
  margin-top: 8rpx;
}
