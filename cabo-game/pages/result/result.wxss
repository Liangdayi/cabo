.result-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a2a6c 0%, #203a43 50%, #2c5364 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.result-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.result-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.result-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.section-title {
  display: block;
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.ranking-section {
  margin-bottom: 40rpx;
}

.ranking-list {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.ranking-item:last-child {
  border-bottom: none;
}

.ranking-item.champion {
  background: rgba(255, 217, 61, 0.15);
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: bold;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.ranking-item.champion .rank-badge {
  background: linear-gradient(135deg, #ffd93d, #f5c800);
  color: #1a1a2e;
}

.rank-avatar {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: bold;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.rank-info {
  flex: 1;
}

.rank-name {
  display: block;
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}

.rank-score {
  display: block;
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
  margin-top: 4rpx;
}

.rank-badge-winner {
  font-size: 40rpx;
}

.stats-section {
  margin-bottom: 40rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-item {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #29ffc6;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  font-weight: bold;
  border: none;
  padding: 28rpx;
  font-size: 32rpx;
}

.btn-primary {
  background: linear-gradient(90deg, #0cebeb, #20e3b2, #29ffc6);
  color: #1a1a2e;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.btn-large {
  padding: 32rpx;
}
