<view class="container">
  <!-- 顶部信息栏 -->
  <view class="top-info">
    <text class="round-info">回合：{{currentRound}}</text>
    <text class="current-player">当前玩家：{{currentPlayerName}}</text>
    <text class="remaining-cards">剩余牌数：{{remainingCards}}</text>
  </view>
  
  <!-- 其他玩家区域 -->
  <view class="other-players">
    <view wx:for="{{otherPlayers}}" wx:key="item.id" class="other-player">
      <text class="player-name">{{item.name}}</text>
      <text class="player-score">得分：{{item.score}}</text>
      <view class="player-cards">
        <view 
          wx:for="{{item.handCards}}" 
          wx:key="index"
          class="card {{card.isFaceUp ? 'face-up' : 'card-back'}}"
        >
          <text wx:if="card.isFaceUp">{{card.value}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 中央牌堆区域 -->
  <view class="central-area">
    <view class="deck-area">
      <view class="card card-back" bindtap="drawFromDeck"></view>
      <text class="deck-label">抽牌堆</text>
    </view>
    
    <view class="discard-area">
      <view class="card face-up" bindtap="drawFromDiscard" wx:if="topDiscardCard">
        <text>{{topDiscardCard}}</text>
      </view>
      <text class="discard-label">弃牌堆</text>
    </view>
  </view>
  
  <!-- 自己的牌 -->
  <view class="my-cards">
    <text class="my-label">我的牌</text>
    <view class="cards-row">
      <view 
        wx:for="{{myHandCards}}" 
        wx:key="index"
        class="card {{card.isFaceUp || card.isKnown ? 'face-up' : 'card-back'}}"
        bindtap="selectCard"
        data-index="{{index}}"
      >
        <text wx:if="card.isFaceUp || card.isKnown">{{card.value}}</text>
      </view>
    </view>
    <text class="my-score">当前得分：{{myScore}}</text>
  </view>
  
  <!-- 操作面板 -->
  <view class="action-panel">
    <button class="action-btn" bindtap="drawFromDeck">抽牌</button>
    <button class="action-btn" bindtap="drawFromDiscard" wx:if="topDiscardCard">捡弃牌</button>
    <button class="action-btn action-btn-cabo" bindtap="callCabo">喊CABO</button>
    <button class="action-btn" bindtap="endTurn">结束回合</button>
  </view>
  
  <!-- 特殊能力弹窗 -->
  <view class="ability-modal" wx:if="showAbilityModal">
    <view class="ability-content">
      <text class="ability-title">特殊能力</text>
      <text class="ability-desc">{{abilityDescription}}</text>
      <view class="ability-actions">
        <button class="btn btn-primary" bindtap="useAbility">使用</button>
        <button class="btn btn-secondary" bindtap="closeAbilityModal">取消</button>
      </view>
    </view>
  </view>
</view>