/* 游戏主页面样式 */
.container {
  padding: 20rpx;
  min-height: 100vh;
  position: relative;
  background-image: 
    radial-gradient(circle at 10% 20%, rgba(87, 197, 182, 0.05) 0%, transparent 50%),
    radial-gradient(circle at 90% 80%, rgba(21, 152, 149, 0.05) 0%, transparent 50%);
}

/* 顶部信息栏 */
.top-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: rgba(26, 95, 122, 0.3);
  border-radius: var(--border-radius);
  padding: 20rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(87, 197, 182, 0.2);
  backdrop-filter: blur(5rpx);
  animation: fadeIn 0.5s ease-out;
}

.round-info,
.current-player,
.remaining-cards {
  font-size: 24rpx;
  color: var(--text-color);
  font-weight: 500;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

.current-player {
  color: var(--accent-color);
  font-weight: bold;
}

/* 其他玩家区域 */
.other-players {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.other-player {
  background-color: rgba(26, 95, 122, 0.2);
  border-radius: var(--border-radius);
  padding: 20rpx;
  transition: var(--transition);
  border: 1rpx solid rgba(87, 197, 182, 0.1);
  backdrop-filter: blur(5rpx);
}

.other-player:hover {
  background-color: rgba(26, 95, 122, 0.3);
  transform: translateY(-3rpx);
  box-shadow: var(--shadow);
}

.other-player .player-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--accent-color);
  margin-bottom: 8rpx;
  display: block;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

.other-player .player-score {
  font-size: 24rpx;
  color: var(--secondary-color);
  margin-bottom: 15rpx;
  display: block;
}

.player-cards {
  display: flex;
  gap: 15rpx;
  flex-wrap: wrap;
}

/* 中央牌堆区域 */
.central-area {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
  padding: 20rpx;
  background-color: rgba(26, 95, 122, 0.1);
  border-radius: var(--border-radius);
  border: 1rpx solid rgba(87, 197, 182, 0.1);
}

.deck-area,
.discard-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
  transition: var(--transition);
}

.deck-area:hover,
.discard-area:hover {
  transform: scale(1.05);
}

.deck-label,
.discard-label {
  font-size: 24rpx;
  color: var(--text-color);
  font-weight: 500;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

/* 自己的牌 */
.my-cards {
  text-align: center;
  margin-bottom: 120rpx; /* 为操作面板留出空间 */
  animation: fadeIn 0.5s ease-out 0.2s both;
}

.my-label {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--accent-color);
  margin-bottom: 20rpx;
  display: block;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.cards-row {
  display: flex;
  justify-content: center;
  gap: 25rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.my-score {
  font-size: 28rpx;
  color: var(--secondary-color);
  font-weight: bold;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

/* 卡片样式 */
.card {
  width: 130rpx;
  height: 180rpx;
  border-radius: 10rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  font-weight: bold;
  box-shadow: var(--shadow);
  cursor: pointer;
  transition: var(--transition);
  position: relative;
  overflow: hidden;
  background-color: var(--card-color);
  color: var(--background-color);
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 12rpx;
  background: linear-gradient(90deg, #ff6b6b, #4ecdc4, #45b7d1);
}

.card:hover {
  transform: translateY(-8rpx) rotate(3deg);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
}

.card-back {
  background-color: var(--card-back-color);
  background-image: 
    radial-gradient(circle at 20% 20%, #666 8%, transparent 8%),
    radial-gradient(circle at 80% 80%, #666 8%, transparent 8%),
    radial-gradient(circle at 40% 60%, #666 6%, transparent 6%),
    radial-gradient(circle at 60% 40%, #666 6%, transparent 6%);
  background-size: 20rpx 20rpx;
  position: relative;
}

.card-back::after {
  content: 'CABO';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 28rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.7);
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.6);
}

.card.face-up {
  background-color: var(--card-color);
  color: var(--background-color);
}

/* 操作面板 */
.action-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(26, 95, 122, 0.95);
  padding: 25rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  box-shadow: 0 -6rpx 25rpx rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(10rpx);
  border-top: 1rpx solid rgba(87, 197, 182, 0.3);
  animation: slideUp 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.action-btn {
  flex: 1;
  min-width: 130rpx;
  height: 85rpx;
  line-height: 85rpx;
  font-size: 26rpx;
  border-radius: var(--border-radius);
  margin: 8rpx 12rpx;
  background-color: var(--secondary-color);
  color: white;
  font-weight: bold;
  transition: var(--transition);
  position: relative;
  overflow: hidden;
  border: none;
  outline: none;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.6s;
}

.action-btn:hover::before {
  left: 100%;
}

.action-btn:hover {
  transform: translateY(-3rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.action-btn:active {
  transform: translateY(0);
}

.action-btn-cabo {
  background-color: var(--accent-color);
  color: var(--background-color);
  box-shadow: 0 4rpx 12rpx rgba(87, 197, 182, 0.4);
}

.action-btn-cabo:hover {
  background-color: #47b0a0;
  transform: translateY(-5rpx);
  box-shadow: 0 6rpx 18rpx rgba(87, 197, 182, 0.6);
}

/* 特殊能力弹窗 */
.ability-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  backdrop-filter: blur(5rpx);
  animation: fadeIn 0.3s ease-out;
}

.ability-content {
  background-color: var(--background-color);
  border-radius: var(--border-radius);
  padding: 50rpx;
  width: 85%;
  max-width: 550rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.6);
  border: 1rpx solid rgba(87, 197, 182, 0.3);
  backdrop-filter: blur(10rpx);
  animation: slideUp 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.ability-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--accent-color);
  margin-bottom: 25rpx;
  display: block;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.ability-desc {
  font-size: 28rpx;
  color: var(--text-color);
  margin-bottom: 40rpx;
  line-height: 1.6;
  display: block;
}

.ability-actions {
  display: flex;
  gap: 25rpx;
}

.ability-actions .btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 26rpx;
  border-radius: var(--border-radius);
  font-weight: bold;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .card {
    width: 110rpx;
    height: 154rpx;
    font-size: 32rpx;
  }
  
  .top-info {
    flex-direction: column;
    gap: 10rpx;
    padding: 15rpx;
  }
  
  .action-btn {
    min-width: 100rpx;
    font-size: 22rpx;
    height: 75rpx;
    line-height: 75rpx;
  }
}

/* 动画效果 */
@keyframes cardShine {
  0% {
    box-shadow: 0 0 0 0 rgba(87, 197, 182, 0.4);
  }
  70% {
    box-shadow: 0 0 0 15rpx rgba(87, 197, 182, 0);
  }
  100% {
    box-shadow: 0 0 0 0 rgba(87, 197, 182, 0);
  }
}

.card.shine {
  animation: cardShine 1s ease-out;
}

/* 特殊效果 */
.cabo-glow {
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.6);
  animation: pulse 2s infinite;
}

.ability-glow {
  box-shadow: 0 0 20rpx rgba(87, 197, 182, 0.6);
  animation: pulse 1.5s infinite;
}