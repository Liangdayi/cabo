/* 房间页面样式 */
.container {
  padding: 30rpx 20rpx;
  min-height: 100vh;
}

.room-info {
  background-color: rgba(26, 95, 122, 0.3);
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.room-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #57C5B6;
  margin-bottom: 10rpx;
  display: block;
}

.player-count {
  font-size: 24rpx;
  color: #159895;
}

.players-list {
  background-color: rgba(26, 95, 122, 0.2);
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
}

.list-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #57C5B6;
  margin-bottom: 20rpx;
  display: block;
}

.players {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.player-item {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 20rpx;
}

.player-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.player-name {
  flex: 1;
  font-size: 26rpx;
  color: #FFFFFF;
}

.player-status {
  font-size: 22rpx;
  padding: 5rpx 15rpx;
  border-radius: 10rpx;
}

.player-status.ready {
  background-color: #57C5B6;
  color: #002B5B;
}

.player-status.waiting {
  background-color: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.btn {
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  border-radius: 12rpx;
}

.tips {
  background-color: rgba(255, 215, 0, 0.1);
  border-radius: 12rpx;
  padding: 20rpx;
}

.tips-text {
  font-size: 22rpx;
  color: #FFD700;
  text-align: center;
  line-height: 1.4;
}