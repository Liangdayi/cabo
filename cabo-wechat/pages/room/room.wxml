<view class="container">
  <view class="room-info">
    <text class="room-title">房间号：{{roomId}}</text>
    <text class="player-count">玩家人数：{{playerCount}}人</text>
  </view>
  
  <view class="players-list">
    <text class="list-title">玩家列表</text>
    <view class="players">
      <view wx:for="{{players}}" wx:key="item.id" class="player-item">
        <image class="player-avatar" src="{{item.avatar || '../../images/default-avatar.png'}}" />
        <text class="player-name">{{item.name}}</text>
        <text class="player-status {{item.isReady ? 'ready' : 'waiting'}}">
          {{item.isReady ? '已准备' : '等待中'}}
        </text>
      </view>
    </view>
  </view>
  
  <view class="actions">
    <button 
      class="btn {{isReady ? 'btn-secondary' : 'btn-primary'}}"
      bindtap="toggleReady"
    >
      {{isReady ? '取消准备' : '准备'}}
    </button>
    
    <button 
      wx:if="isCreator" 
      class="btn btn-accent" 
      bindtap="startGame"
      disabled="{{!canStartGame}}"
    >
      开始游戏
    </button>
  </view>
  
  <view class="tips">
    <text class="tips-text">提示：所有玩家准备后，房主可以开始游戏</text>
  </view>
</view>