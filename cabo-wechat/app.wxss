/* 全局样式 */
page {
  background-color: #002B5B;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  color: #FFFFFF;
  line-height: 1.5;
}

/* CSS变量 */
:root {
  --primary-color: #1A5F7A;
  --secondary-color: #159895;
  --accent-color: #57C5B6;
  --background-color: #002B5B;
  --card-color: #FFFFFF;
  --card-back-color: #4A4A4A;
  --text-color: #FFFFFF;
  --shadow: 0 4px 12px rgba(0, 0, 0, 0.3);
  --border-radius: 12rpx;
  --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 主色调 */
.primary-color {
  color: var(--primary-color);
}

.secondary-color {
  color: var(--secondary-color);
}

.accent-color {
  color: var(--accent-color);
}

/* 按钮样式 */
.btn {
  display: inline-block;
  padding: 12px 24px;
  border-radius: var(--border-radius);
  font-size: 16px;
  font-weight: bold;
  text-align: center;
  cursor: pointer;
  transition: var(--transition);
  border: none;
  outline: none;
  position: relative;
  overflow: hidden;
}

.btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.6s;
}

.btn:hover::before {
  left: 100%;
}

.btn-primary {
  background-color: var(--primary-color);
  color: white;
}

.btn-primary:hover {
  background-color: #0f4a60;
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}

.btn-secondary {
  background-color: var(--secondary-color);
  color: white;
}

.btn-secondary:hover {
  background-color: #0f7a77;
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}

.btn-accent {
  background-color: var(--accent-color);
  color: var(--background-color);
}

.btn-accent:hover {
  background-color: #47b0a0;
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}

/* 卡片样式 */
.card {
  width: 120rpx;
  height: 168rpx;
  border-radius: 8rpx;
  background-color: var(--card-color);
  color: var(--background-color);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: var(--shadow);
  transition: var(--transition);
  position: relative;
  overflow: hidden;
}

.card:hover {
  transform: translateY(-5rpx) rotate(2deg);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 10rpx;
  background: linear-gradient(90deg, #ff6b6b, #4ecdc4);
}

.card-back {
  background-color: var(--card-back-color);
  background-image: 
    radial-gradient(circle at 20% 20%, #666 8%, transparent 8%),
    radial-gradient(circle at 80% 80%, #666 8%, transparent 8%),
    radial-gradient(circle at 40% 60%, #666 6%, transparent 6%),
    radial-gradient(circle at 60% 40%, #666 6%, transparent 6%);
  background-size: 20rpx 20rpx;
  position: relative;
}

.card-back::after {
  content: 'CABO';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 24rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.7);
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.5);
}

/* 容器样式 */
.container {
  padding: 30rpx 20rpx;
  min-height: 100vh;
}

/* 标题样式 */
.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: var(--accent-color);
  text-align: center;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
  position: relative;
}

.title::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--accent-color), transparent);
}

.subtitle {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: var(--secondary-color);
  text-align: center;
}

/* 玩家样式 */
.player {
  display: flex;
  align-items: center;
  padding: 15rpx;
  margin-bottom: 15rpx;
  background-color: rgba(26, 95, 122, 0.3);
  border-radius: var(--border-radius);
  transition: var(--transition);
  border: 1rpx solid rgba(87, 197, 182, 0.2);
}

.player:hover {
  background-color: rgba(26, 95, 122, 0.5);
  transform: translateX(10rpx);
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 3rpx solid var(--accent-color);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.player-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
}

.player-score {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--accent-color);
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

/* 操作面板 */
.action-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(26, 95, 122, 0.95);
  padding: 20rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(10rpx);
  border-top: 1rpx solid rgba(87, 197, 182, 0.3);
}

/* 动画效果 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { transform: translateY(100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.fade-in {
  animation: fadeIn 0.5s ease-out;
}

.slide-up {
  animation: slideUp 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.pulse {
  animation: pulse 2s infinite;
}

.rotate {
  animation: rotate 2s linear infinite;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .card {
    width: 100rpx;
    height: 140rpx;
    font-size: 30rpx;
  }
  
  .title {
    font-size: 40rpx;
  }
  
  .subtitle {
    font-size: 28rpx;
  }
}

/* 辅助类 */
.text-center {
  text-align: center;
}

.text-left {
  text-align: left;
}

.text-right {
  text-align: right;
}

.mt-10 {
  margin-top: 10rpx;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.p-10 {
  padding: 10rpx;
}

.p-20 {
  padding: 20rpx;
}

/* 卡片翻转效果 */
.card-container {
  perspective: 1000rpx;
}

.card-flip {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.6s;
  transform-style: preserve-3d;
}

.card-container:hover .card-flip {
  transform: rotateY(180deg);
}

.card-front, .card-back {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
}

.card-back {
  transform: rotateY(180deg);
}